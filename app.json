{
  "expo": {
    "name": "LifeList",
    "slug": "lifelist",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lifelist",
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sarahursula.lifelist"
    },
    "android": {
      "package": "com.sarahursula.lifelist",
      "adaptiveIcon": {
        "backgroundColor": "#6366f1"
      }
    }
  }
}
